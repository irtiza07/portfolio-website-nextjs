# Copy this file to `.env.local` and fill in real values.
# `.env.local` is gitignored; this template is committed.

# YouTube Data API v3 key, used at build time by getYoutubeVideos() in
# lib/logic.js to fetch recent uploads for the homepage grid and the
# section-page carousels.
#
# Create one at https://console.cloud.google.com/apis/credentials with the
# "YouTube Data API v3" enabled. A browser-key restriction is not useful here
# since the key is only ever read server-side during `next build`.
#
# Without this key the fetch returns nothing, and the video sections render
# nothing rather than failing the build.
YOUTUBE_API_KEY=
